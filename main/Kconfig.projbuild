menu "Tomato Glow Clock"

config TOMATO_WIFI_SSID
    string "WiFi SSID"
    default ""
    help
        WiFi network name used by Tomato Glow Clock for time sync and weather.

config TOMATO_WIFI_PASS
    string "WiFi password"
    default ""
    help
        WiFi password. Leave empty for an open network.

config TOMATO_QWEATHER_API_KEY
    string "Legacy QWeather API key"
    default ""
    help
        QWeather API key credential. Tomato Glow Clock prefers local JWT signing
        when main/APP/qweather_jwt_secret.h is present, otherwise it uses this key.

config TOMATO_QWEATHER_API_HOST
    string "QWeather API Host"
    default "devapi.qweather.com"
    help
        QWeather API Host from Console - Settings, for example
        abc1234xyz.def.qweatherapi.com. The legacy devapi.qweather.com may return
        Invalid Host for newer credentials.

config TOMATO_QWEATHER_LOCATION
    string "QWeather location"
    default "113.53,22.49"
    help
        QWeather location ID or longitude,latitude. Default is Zhongshan Nanlang.

endmenu
